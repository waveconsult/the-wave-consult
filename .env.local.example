# The Wave Consult — environment (briefing §8)
# Copy to .env.local and fill in. NEVER commit .env.local.
#
# Security boundary: the service-role key is SERVER-ONLY. Never expose it to the
# browser, never hard-code keys in source, never paste real keys into a chat.

# From Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY — used in admin route handlers / Storage uploads
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for metadata / canonical)
NEXT_PUBLIC_SITE_URL=https://thewaveconsult.com

# Storage: set to "true" if the `bet-shots` bucket is PUBLIC read.
# Leave "false" (default) to serve bet-slip screenshots via signed URLs.
NEXT_PUBLIC_BET_SHOTS_PUBLIC=false
